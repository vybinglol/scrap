{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scrapable",
  "version": "0.1.0",
  "identifier": "lol.vybing.scrapable",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scrapable",
        "url": "/app",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vybinglol/scrap/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGOTY2MjIxQUE5MUEzQjkKUldTNW81R3FJV0tXendoUjFiU21haTFnbk1xWnRvSm54WEZqVURieWZzKzBONUdjYncxTU9MVkkK"
    }
  }
}
